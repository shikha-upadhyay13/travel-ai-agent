# ===== Server Configuration =====
CORS_ORIGINS=http://localhost:8000
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60

# ===== Database =====
DB_PATH=travel_agent.db

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=
